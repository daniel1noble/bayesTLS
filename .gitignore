.httr-oauth

# Sims — ignore the per-sim raw files (1000s of small RDS files,
# regeneratable from scripts/sim_twostage_bias.R). Track only the aggregated
# outputs the supplement loads at render time (per_sim, draws, summary, diffs).
output/sim_twostage/raw/

# knitr and R markdown default cache directories
*_cache/
/cache/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# R Environment Variables
.Renviron

# pkgdown site
docs/

# translation temp files
po/*~

# RStudio Connect folder
rsconnect/
.DS_Store

# Local/editor settings
.claude/
.vscode/

/.luarc.json

/.quarto/

# ---- Render outputs --------------------------------------------------------
# Final deliverables go to _output/ via `make ms`, `make supp`, `make ms-supp`,
# `make all`. Track the artefacts so collaborators can grab them without
# rendering; ignore intermediate per-source build artefacts.
_output/*
!_output/*.pdf
!_output/*.docx
!_output/*.html

# Per-source intermediates inside ms/: rendered output before move to _output/,
# knitr cache, figure dirs, .quarto scratch.
ms/*.html
ms/*.docx
ms/*.pdf
ms/.quarto/
*_files/

# Quarto build caches
*_cache/
