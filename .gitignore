output/models/smoke_phase1d/
output/figs/smoke_phase1d/
output/models/link_test/
scripts/smoke-test-phase1a.R
scripts/smoke-test-phase1b.R
scripts/smoke-test-phase1c.R
scripts/smoke-test-phase1d.R

