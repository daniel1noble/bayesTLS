.httr-oauth

# Sims — ignore ALL simulation .rds outputs (per-sim raw files AND aggregates).
# They are regeneratable from scripts/sim_twostage_bias.R. The mock_sim and
# *_buggy_* sibling directories are also ignored.
output/sim_twostage/
output/sim_twostage_*/
output/sim_twostage_buggy_*/
output/mock_sim/
output/figs/sim_twostage/

# knitr and R markdown default cache directories
*_cache/
/cache/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# R Environment Variables
.Renviron

# pkgdown site
docs/

# translation temp files
po/*~

# RStudio Connect folder
rsconnect/
.DS_Store

# Local/editor settings
.claude/
.vscode/

/.luarc.json

/.quarto/

# ---- Render outputs --------------------------------------------------------
# Final deliverables go to _output/ via `make ms`, `make supp`, `make ms-supp`,
# `make all`. Track the artefacts so collaborators can grab them without
# rendering; ignore intermediate per-source build artefacts.
_output/*
!_output/*.pdf
!_output/*.docx
!_output/*.html

# Per-source intermediates inside ms/: rendered output before move to _output/,
# knitr cache, figure dirs, .quarto scratch.
ms/*.html
ms/*.docx
ms/*.pdf
ms/.quarto/
*_files/

# Quarto build caches
*_cache/
bib/tdt_problems.bib.before-bbt-migration.20260507
index.log
ms/ms.log
ms/supplement.tex
ms/ms_supp.tex
